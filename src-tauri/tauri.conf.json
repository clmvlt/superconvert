{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SuperConvert",
  "version": "0.0.7",
  "identifier": "com.superconvert.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SuperConvert",
        "width": 820,
        "height": 350,
        "minWidth": 600,
        "minHeight": 350,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "backgroundColor": [9, 9, 11, 255]
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13",
      "signingIdentity": "-",
      "hardenedRuntime": false
    },
    "category": "Utility",
    "shortDescription": "Fast cross-platform file converter",
    "longDescription": "SuperConvert is a fast, cross-platform file converter supporting images, audio, video, and documents."
  },
  "plugins": {}
}
